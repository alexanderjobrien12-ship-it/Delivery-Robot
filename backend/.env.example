# Copy this file to a new file called ".env" and fill in your real values.
# The .env file keeps your passwords secret — it never gets uploaded to the internet.

# Your Gmail address
GMAIL_USER=you@gmail.com

# An "App Password" from Google (not your real Gmail password).
# How to get one: Google Account → Security → 2-Step Verification → App Passwords
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# The email address that receives order notifications (probably the same as above)
NOTIFY_EMAIL=alexanderjobrien12@gmail.com

# A secret word the robot uses to prove it's allowed to talk to this server.
# Make up anything you like, e.g. "lego-robot-secret-42"
ROBOT_SECRET=change-me-to-something-secret

# The public URL of this server — used to build the status-update links in emails.
# While testing at home, leave this blank (it defaults to localhost).
# Once deployed to Render, set this to your Render URL, e.g. https://lego-delivery.onrender.com
BACKEND_PUBLIC_URL=
